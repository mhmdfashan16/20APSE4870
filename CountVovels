
//Count Vovels in a String
fun main() {
    val text = "Kotlin Programming"
    var count = 0

    for (char in text.lowercase()) {
        if (char == 'a' || char == 'e' || char == 'i' || char == 'o' || char == 'u') {
            count++
        }
    }

    println("Number of vowels: $count")
}

